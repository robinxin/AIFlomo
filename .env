# 前端环境变量（EXPO_PUBLIC_ 前缀会打包到前端代码）
EXPO_PUBLIC_API_URL=http://localhost:3000

# Session 签名密钥 — 必须 ≥ 32 字符，建议使用 96 字节（192 个十六进制字符）随机密钥
# 生成命令: node -e "const{randomBytes}=require('crypto');console.log(randomBytes(96).toString('hex'))"
SESSION_SECRET=3b5bcc3c03da0b25fb0edc4616910fbd948d5a937706ddb2a41d5a814f469dcddc002443fbf20a6199b3b86d8d6d69ca5becfe49628adcefcb3db39cf6dcd1ff24e948b0cd64abb3d0005fcf53f7ceb364dac9b64303a8db3d35e98e24a074e6

# CORS 白名单域名（逗号分隔，生产环境替换为实际域名）
ALLOWED_ORIGINS=http://localhost:8082

# 模型配置（全局，不含业务账号密码）
OPENAI_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
OPENAI_API_KEY="your-volcano-api-key-here"
# MIDSCENE_MODEL_NAME="ep-20251106190045-6wpnr" # Inference endpoint ID or model name from Volcano Engine
MIDSCENE_USE_DOUBAO_VISION=1

MIDSCENE_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MIDSCENE_MODEL_API_KEY=your-volcano-api-key-here
MIDSCENE_MODEL_NAME=ep-20251106190045-6wpnr   # 你的推理 endpoint ID
MIDSCENE_MODEL_FAMILY=doubao-vision  # 或 doubao-seed，看你在火山方舟上用的是哪种
