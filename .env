# 模型配置（全局，不含业务账号密码）
OPENAI_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
OPENAI_API_KEY="49ee41ed-d041-486d-a883-614845689b5a"
# MIDSCENE_MODEL_NAME="ep-20251106190045-6wpnr" # Inference endpoint ID or model name from Volcano Engine
MIDSCENE_USE_DOUBAO_VISION=1

MIDSCENE_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MIDSCENE_MODEL_API_KEY=49ee41ed-d041-486d-a883-614845689b5a
MIDSCENE_MODEL_NAME=ep-20251106190045-6wpnr   # 你的推理 endpoint ID
MIDSCENE_MODEL_FAMILY=doubao-vision  # 或 doubao-seed，看你在火山方舟上用的是哪种

# 后端服务配置
PORT=3000
NODE_ENV=development

# Session 密钥（生产环境请替换为随机长字符串，至少 32 字符）
SESSION_SECRET=aiflomo-dev-secret-change-in-production-32chars

# 数据库路径（默认为 apps/server/data/aiflomo.db，CI 通过环境变量覆盖）
# DB_PATH=/absolute/path/to/aiflomo.db

# CORS 白名单（逗号分隔，生产环境必须配置真实域名）
# 开发环境已自动允许 localhost:8081 / 8082 / 5173，无需填写
# 示例（生产）：CORS_ALLOWED_ORIGINS=https://aiflomo.example.com
CORS_ALLOWED_ORIGINS=
