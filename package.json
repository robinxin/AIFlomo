{
  "name": "aiflomo",
  "version": "0.1.0",
  "private": true,
  "description": "复刻 Flomo 体验的全栈 MVP，支持 Web、Android、iOS 三端",
  "workspaces": [
    "apps/mobile",
    "apps/server",
    "apps/tests"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/server & npm run dev --workspace=apps/mobile",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspace=apps/tests"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
