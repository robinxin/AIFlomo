{
  "name": "@aiflomo/server",
  "version": "1.0.0",
  "description": "AIFlomo backend server - Node.js + Fastify",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/main.js",
    "build": "cp -r src dist",
    "lint": "eslint src tests",
    "prod": "pm2 start dist/main.js --name aiflomo-server",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node src/db/migrate.js",
    "db:reset": "node src/db/reset.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:unit:cov": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "drizzle-orm": "^0.38.0",
    "better-sqlite3": "^11.0.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "bcrypt": "^5.1.1",
    "@fastify/session": "^11.0.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "@babel/preset-env": "^7.25.0",
    "drizzle-kit": "^0.30.0"
  }
}
