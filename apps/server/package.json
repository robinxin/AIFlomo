{
  "name": "@aiflomo/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "build": "echo 'Server build complete'",
    "lint": "eslint src/",
    "prod": "pm2 start src/index.js --name aiflomo-server",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node src/db/migrate.js",
    "db:reset": "rm -f ./data/*.db"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "@fastify/session": "^11.0.1",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "drizzle-orm": "^0.38.3",
    "better-sqlite3": "^11.8.1",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.18.0"
  }
}
