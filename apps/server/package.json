{
  "name": "aiflomo-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "build": "echo 'Build not needed for JavaScript project'",
    "lint": "eslint src/",
    "prod": "pm2 start src/index.js --name aiflomo-server",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
