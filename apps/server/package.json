{
  "name": "@aiflomo/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "build": "node build.js",
    "lint": "eslint src/",
    "prod": "pm2 start dist/index.js --name aiflomo-server",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "rm -f aiflomo.db && pnpm db:migrate",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:unit:cov": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "fastify": "^5.1.0",
    "drizzle-orm": "^0.37.0",
    "better-sqlite3": "^11.7.0",
    "@fastify/session": "^11.0.1",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "drizzle-kit": "^0.29.0",
    "eslint": "^9.0.0",
    "jest": "^30.0.0-alpha.0",
    "@babel/preset-env": "^7.25.0"
  }
}
