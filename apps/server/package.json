    "@fastify/cookie": "^10.0.0",
    "@fastify/session": "^11.0.0",
    "@fastify/cors": "^10.0.1",
    "@mgcrea/fastify-session-sqlite-store": "^1.0.0",
    "bcrypt": "^5.1.1",
    "drizzle-orm": "^0.37.0",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.19.0"
  }
}
