{
  "name": "@aiflomo/server",
  "version": "1.0.0",
  "description": "AIFlomo backend server — Fastify + SQLite + Drizzle ORM",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "build": "node --check src/index.js && echo 'Build OK'",
    "lint": "eslint src tests",
    "prod": "pm2 start src/index.js --name aiflomo-server",
    "test:unit": "node node_modules/jest/bin/jest.js",
    "test:unit:watch": "node node_modules/jest/bin/jest.js --watch",
    "test:unit:cov": "node node_modules/jest/bin/jest.js --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node src/db/migrate.js",
    "db:reset": "node src/db/reset.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/session": "^11.1.1",
    "better-sqlite3": "^11.0.0",
    "better-sqlite3-session-store": "^0.1.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.25.0",
    "babel-jest": "^29.7.0",
    "drizzle-kit": "^0.30.0",
    "jest": "^29.7.0"
  }
}
