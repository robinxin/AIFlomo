{
  "name": "@aiflomo/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "build": "mkdir -p dist && cp -r src/* dist/",
    "lint": "eslint src/",
    "prod": "pm2 start src/index.js --name aiflomo-server",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node src/db/migrate.js",
    "db:reset": "node -e \"import('./src/db/reset.js')\"",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:unit:cov": "jest --coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/session": "^11.0.1",
    "better-sqlite3": "^11.9.1",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.25.0",
    "drizzle-kit": "^0.30.4",
    "jest": "^30.0.0-alpha.0"
  }
}
