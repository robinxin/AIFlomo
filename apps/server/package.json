{
  "name": "aiflomo-server",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "build": "node -e \"console.log('No build step required for Node.js')\"",
    "lint": "eslint src/ tests/",
    "prod": "pm2 start src/index.js --name aiflomo-server",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node src/db/migrate.js",
    "db:reset": "node src/db/reset.js",
    "test:unit": "node --experimental-vm-modules ../../node_modules/.bin/jest",
    "test:unit:watch": "node --experimental-vm-modules ../../node_modules/.bin/jest --watch",
    "test:unit:cov": "node --experimental-vm-modules ../../node_modules/.bin/jest --coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/session": "^11.0.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.30.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.20.0",
    "eslint": "^8.57.0"
  }
}
