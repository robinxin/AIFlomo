{
  "name": "@aiflomo/mobile",
  "version": "1.0.0",
  "description": "AIFlomo mobile app (Expo - Web/Android/iOS)",
  "main": "expo-router",
  "type": "module",
  "scripts": {
    "dev": "expo start",
    "build": "expo export -p web",
    "lint": "eslint app/**/*.jsx components/**/*.jsx --max-warnings 0",
    "prod": "echo 'Production build and deploy - configure deployment script'",
    "start": "expo start",
    "web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-router": "~4.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.5"
  },
  "private": true
}
