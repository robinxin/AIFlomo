{
  "name": "aiflomo-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "npx expo start",
    "dev:web": "npx expo start --web",
    "dev:android": "npx expo start --android",
    "dev:ios": "npx expo start --ios",
    "build": "npx expo export --platform web",
    "lint": "eslint app/ components/ context/ hooks/ lib/ --ext .js,.jsx 2>/dev/null || eslint app/ context/ lib/ --ext .js,.jsx",
    "prod": "npm run build && echo 'Deploy dist/ to Nginx'"
  },
  "dependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@expo/metro-runtime": "~4.0.1",
    "expo": "~52.0.28",
    "expo-router": "~4.0.18",
    "expo-status-bar": "~2.0.1",
    "globals": "^17.4.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.7",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~12.0.9",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0"
  }
}
