{
  "name": "@aiflomo/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "pnpm dlx expo start",
    "build": "pnpm dlx expo export",
    "lint": "eslint app/ components/ context/ hooks/ lib/",
    "prod": "pnpm run build && echo 'Deploy dist/ to Nginx static directory'",
    "test:unit": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:cov": "vitest --coverage",
    "test:unit:watch": "vitest --watch"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-router": "~4.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-image-picker": "~16.0.0",
    "react": "18.3.1",
    "react-native": "0.76.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/ui": "^2.1.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "vitest": "^2.1.0"
  }
}
