{
  "name": "@aiflomo/mobile",
  "version": "1.0.0",
  "description": "AIFlomo frontend — Expo (React Native) cross-platform app",
  "main": "app/_layout.jsx",
  "scripts": {
    "dev": "expo start",
    "build": "expo export",
    "lint": "eslint app/ components/ context/ hooks/ lib/",
    "prod": "expo export && echo 'Deploy dist/ to Nginx static directory'",
    "test:unit": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:cov": "vitest --coverage",
    "test:unit:watch": "vitest --watch"
  },
  "dependencies": {
    "expo": "~52.0.0",
    "expo-router": "~4.0.0",
    "react": "18.3.1",
    "react-native": "0.76.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.0",
    "jsdom": "^25.0.0",
    "vitest": "^2.1.0"
  }
}
