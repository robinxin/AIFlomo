{
  "feature": "账号注册与登录",
  "spec_file": "specs/active/25-feature-user-registration-login.md",
  "design_file": "specs/active/25-feature-user-registration-login-design.md",
  "created_date": "2026-03-05",
  "status": "已完成",
  "tech_stack": {
    "backend": "Node.js + Fastify + Drizzle ORM + SQLite + JavaScript",
    "frontend": "Expo (React Native) + JavaScript + React Context",
    "auth": "Session + Cookie (存储于 SQLite)"
  },

  "phases": [
    {
      "phase_id": 1,
      "phase_name": "阶段一：基础准备（数据库 & 公共模块）",
      "description": "所有用户故事共同依赖的底层准备，必须在所有故事前完成",
      "priority": "P0",
      "tasks": [
        {
          "task_id": "T001",
          "title": "扩展 Drizzle Schema，新增 users 表定义",
          "file_path": "apps/server/src/db/schema.js",
          "type": "backend",
          "parallel": true,
          "status": "completed",
          "description": "在 schema.js 中定义 users 表，包含 id, email, passwordHash, nickname, createdAt, lastLoginAt 字段",
          "acceptance_criteria": [
            "users 表包含所有必需字段",
            "email 字段设置 unique() 约束",
            "id 使用 UUID 主键",
            "createdAt 使用 CURRENT_TIMESTAMP 默认值"
          ],
          "dependencies": []
        },
        {
          "task_id": "T002",
          "title": "创建密码工具函数，封装 bcrypt 哈希和验证逻辑",
          "file_path": "apps/server/src/lib/password.js",
          "type": "backend",
          "parallel": true,
          "status": "completed",
          "description": "创建 hashPassword 和 verifyPassword 函数，使用 bcrypt (salt rounds = 10)",
          "acceptance_criteria": [
            "hashPassword 函数接受密码字符串，返回 bcrypt 哈希值",
            "verifyPassword 函数接受密码和哈希，返回布尔值",
            "salt rounds 设置为 10"
          ],
          "dependencies": []
        },
        {
          "task_id": "T003",
          "title": "实现 Fastify session 插件配置，集成 SQLite session store",
          "file_path": "apps/server/src/plugins/session.js",
          "type": "backend",
          "parallel": true,
          "status": "completed",
          "description": "配置 @fastify/session + @mgcrea/fastify-session-sqlite-store，设置 Cookie 安全选项",
          "acceptance_criteria": [
            "Session 存储在 SQLite 数据库",
            "Cookie 设置 httpOnly: true, sameSite: 'strict'",
            "生产环境 secure: true",
            "maxAge 设置为 7 天",
            "SESSION_SECRET 从环境变量读取"
          ],
          "dependencies": []
        },
        {
          "task_id": "T004",
          "title": "创建 requireAuth preHandler，用于保护需登录的路由",
          "file_path": "apps/server/src/plugins/auth.js",
          "type": "backend",
          "parallel": false,
          "status": "completed",
          "description": "实现 requireAuth 中间件，检查 request.session.userId 是否存在",
          "acceptance_criteria": [
            "未登录时返回 401 状态码",
            "错误响应包含 error: 'Unauthorized', message: '请先登录'",
            "已登录时放行请求"
          ],
          "dependencies": ["T003"]
        }
      ]
    },

    {
      "phase_id": 2,
      "phase_name": "阶段二：用户故事 1 - 邮箱密码登录（优先级：P1）",
      "description": "用户可通过邮箱和密码登录，验证成功后创建 Session 并跳转到主应用",
      "priority": "P1",
      "user_story": "用户访问应用时，可以通过输入邮箱和密码完成登录，进入主应用界面",
      "tasks": [
        {
          "task_id": "T005",
          "title": "实现 POST /api/auth/login 路由",
          "file_path": "apps/server/src/routes/auth.js",
          "type": "backend",
          "parallel": true,
          "status": "completed",
          "description": "实现登录端点，包含 JSON Schema 验证、bcrypt 密码验证、Session 创建、lastLoginAt 更新",
          "acceptance_criteria": [
            "使用 JSON Schema 验证邮箱和密码格式",
            "邮箱统一转为小写",
            "使用 bcrypt.compare 验证密码",
            "验证成功后更新 lastLoginAt",
            "创建 Session (request.session.userId = user.id)",
            "返回用户信息（不包含 passwordHash）",
            "邮箱不存在或密码错误统一返回 401"
          ],
          "dependencies": ["T001", "T002", "T003", "T004"]
        },
        {
          "task_id": "T006",
          "title": "实现 POST /api/auth/logout 路由",
          "file_path": "apps/server/src/routes/auth.js",
          "type": "backend",
          "parallel": true,
          "status": "completed",
          "description": "实现登出端点，销毁 Session 并返回 204",
          "acceptance_criteria": [
            "使用 preHandler: [requireAuth]",
            "调用 request.session.destroy()",
            "返回 204 No Content"
          ],
          "dependencies": ["T004"]
        },
        {
          "task_id": "T007",
          "title": "实现 GET /api/auth/me 路由",
          "file_path": "apps/server/src/routes/auth.js",
          "type": "backend",
          "parallel": true,
          "status": "completed",
          "description": "实现获取当前用户信息端点",
          "acceptance_criteria": [
            "使用 preHandler: [requireAuth]",
            "从 Session 获取 userId",
            "查询用户信息并返回（不包含 passwordHash）",
            "用户不存在时返回 401"
          ],
          "dependencies": ["T001", "T004"]
        },
        {
          "task_id": "T008",
          "title": "创建 AuthContext，使用 useReducer 管理登录状态",
          "file_path": "apps/mobile/context/AuthContext.jsx",
          "type": "frontend",
          "parallel": false,
          "status": "completed",
          "description": "创建认证 Context，管理 user, isAuthenticated, isLoading 状态",
          "acceptance_criteria": [
            "定义 initialState: { user: null, isAuthenticated: false, isLoading: true }",
            "实现 Reducer 处理 LOGIN_SUCCESS, LOGOUT, CHECK_AUTH_START, CHECK_AUTH_SUCCESS, CHECK_AUTH_FAILURE",
            "导出 useAuth Hook",
            "AuthProvider 包裹 children"
          ],
          "dependencies": []
        },
        {
          "task_id": "T009",
          "title": "创建 useCheckAuth Hook，应用启动时检测登录状态",
          "file_path": "apps/mobile/hooks/use-check-auth.js",
          "type": "frontend",
          "parallel": false,
          "status": "completed",
          "description": "实现启动时调用 GET /api/auth/me 检测登录状态的 Hook",
          "acceptance_criteria": [
            "调用 GET /api/auth/me",
            "成功时 dispatch CHECK_AUTH_SUCCESS",
            "失败时 dispatch CHECK_AUTH_FAILURE",
            "使用 useEffect 自动执行"
          ],
          "dependencies": ["T008"]
        },
        {
          "task_id": "T010",
          "title": "创建登录页面",
          "file_path": "apps/mobile/app/(auth)/login.jsx",
          "type": "frontend",
          "parallel": false,
          "status": "completed",
          "description": "实现登录页面，包含邮箱密码输入框、前端校验、调用登录 API、跳转逻辑",
          "acceptance_criteria": [
            "邮箱输入框 (keyboardType='email-address')",
            "密码输入框 (secureTextEntry={true})",
            "前端校验：邮箱格式、密码非空",
            "调用 POST /api/auth/login",
            "成功后 dispatch LOGIN_SUCCESS 并 router.replace('/memo')",
            "错误时显示错误提示",
            "使用 StyleSheet.create 定义样式"
          ],
          "dependencies": ["T008"]
        },
        {
          "task_id": "T011",
          "title": "创建认证路由组布局",
          "file_path": "apps/mobile/app/(auth)/_layout.jsx",
          "type": "frontend",
          "parallel": true,
          "status": "completed",
          "description": "创建认证路由组布局，使用 Stack 模式（无 Tab 导航）",
          "acceptance_criteria": [
            "使用 Stack 组件",
            "screenOptions={{ headerShown: false }}",
            "注册 login 和 register Screen"
          ],
          "dependencies": []
        },
        {
          "task_id": "T012",
          "title": "修改根布局，集成 AuthProvider、调用 useCheckAuth",
          "file_path": "apps/mobile/app/_layout.jsx",
          "type": "frontend",
          "parallel": false,
          "status": "completed",
          "description": "在根布局中集成认证逻辑，根据登录状态控制路由重定向",
          "acceptance_criteria": [
            "包裹 <AuthProvider>",
            "调用 useCheckAuth()",
            "isLoading 时显示加载界面",
            "未登录时重定向到 /login",
            "已登录时显示主应用"
          ],
          "dependencies": ["T008", "T009"]
        }
      ]
    },

    {
      "phase_id": 3,
      "phase_name": "阶段三：用户故事 2 - 新用户注册（优先级：P2）",
      "description": "新用户可注册账号并自动登录进入主应用",
      "priority": "P2",
      "user_story": "新用户可以通过输入邮箱、昵称、密码并勾选隐私协议完成账号注册，注册成功后自动登录",
      "tasks": [
        {
          "task_id": "T013",
          "title": "实现 POST /api/auth/register 路由",
          "file_path": "apps/server/src/routes/auth.js",
          "type": "backend",
          "parallel": false,
          "status": "completed",
          "description": "实现注册端点，包含 JSON Schema 验证、邮箱唯一性校验、密码哈希、自动登录",
          "acceptance_criteria": [
            "JSON Schema 验证：email (format: email), password (8-20位，含字母数字), nickname (1-20字符), agreePrivacy (const: true)",
            "邮箱统一转为小写",
            "使用 bcrypt 哈希密码",
            "插入 users 表",
            "捕获 SQLITE_CONSTRAINT 错误，返回 409",
            "成功后自动登录 (request.session.userId = newUser.id)",
            "返回 201 和用户信息（不包含 passwordHash）"
          ],
          "dependencies": ["T001", "T002", "T003"]
        },
        {
          "task_id": "T014",
          "title": "创建注册页面",
          "file_path": "apps/mobile/app/(auth)/register.jsx",
          "type": "frontend",
          "parallel": false,
          "status": "completed",
          "description": "实现注册页面，包含邮箱昵称密码输入框、隐私协议勾选框、前端校验、调用注册 API",
          "acceptance_criteria": [
            "邮箱输入框 (keyboardType='email-address')",
            "昵称输入框 (maxLength=20)",
            "密码输入框 (secureTextEntry={true})",
            "隐私协议勾选框（未勾选时禁用按钮）",
            "前端校验：邮箱格式、密码 8-20 位且含字母数字、昵称 1-20 字符",
            "调用 POST /api/auth/register",
            "成功后自动跳转到 /memo（无需再次登录）",
            "错误时显示错误提示"
          ],
          "dependencies": ["T008"]
        }
      ]
    },

    {
