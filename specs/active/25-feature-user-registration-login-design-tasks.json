          ],
          "dependencies": ["T010"]
        },
        {
          "task_id": "T016",
          "title": "在注册页添加"返回登录"链接",
          "file_path": "apps/mobile/app/(auth)/register.jsx",
          "type": "frontend",
          "parallel": true,
          "status": "completed",
          "description": "添加跳转到登录页的链接",
          "acceptance_criteria": [
