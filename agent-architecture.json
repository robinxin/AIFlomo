{
  "project": {
    "name": "AIFlomo - Agent Collaboration Framework",
    "version": "1.0.0",
    "description": "一个展示 Agent 协作最佳实践的框架"
  },
  "agents": [
    {
      "id": "explorer",
      "name": "Explorer Agent",
      "description": "负责代码搜索、文件分析和上下文理解",
      "capabilities": [
        "code_search",
        "file_analysis",
        "dependency_mapping",
        "context_gathering"
      ],
      "priority": "high",
      "dependencies": [],
      "timeout_ms": 30000
    },
    {
      "id": "planner",
      "name": "Planner Agent",
      "description": "负责架构设计、方案制定和技术决策",
      "capabilities": [
        "architecture_design",
        "task_decomposition",
        "risk_assessment",
        "approach_recommendation"
      ],
      "priority": "high",
      "dependencies": [],
      "timeout_ms": 30000
    },
    {
      "id": "executor",
      "name": "Executor Agent",
      "description": "负责代码实现、文件修改和功能开发",
      "capabilities": [
        "code_generation",
        "file_modification",
        "implementation",
        "testing"
      ],
      "priority": "medium",
      "dependencies": ["planner"],
      "timeout_ms": 60000
    },
    {
      "id": "validator",
      "name": "Validator Agent",
      "description": "负责测试、验证和质量检查",
      "capabilities": [
        "test_execution",
        "code_review",
        "quality_check",
        "performance_validation"
      ],
      "priority": "medium",
      "dependencies": ["executor"],
      "timeout_ms": 45000
    },
    {
      "id": "documentor",
      "name": "Documentor Agent",
      "description": "负责文档生成和知识保留",
      "capabilities": [
        "documentation_generation",
        "comment_writing",
        "example_creation",
        "guide_creation"
      ],
      "priority": "low",
      "dependencies": ["executor"],
      "timeout_ms": 20000
    },
    {
      "id": "coordinator",
      "name": "Coordinator Agent",
      "description": "负责任务编排、流程管理和结果整合",
      "capabilities": [
        "task_scheduling",
        "resource_allocation",
        "progress_tracking",
        "result_aggregation",
        "error_handling"
      ],
      "priority": "critical",
      "dependencies": [],
      "timeout_ms": 120000
    }
  ],
  "collaboration_patterns": [
    {
      "name": "feature_development",
      "description": "完整的功能开发工作流",
      "steps": [
        {
          "stage": "discovery",
          "agents": ["explorer", "planner"],
          "mode": "parallel",
          "description": "同时进行代码探索和方案设计"
        },
        {
          "stage": "planning",
          "agents": ["coordinator"],
          "mode": "sequential",
          "description": "协调员审阅并确认方案"
        },
        {
          "stage": "implementation",
          "agents": ["executor"],
          "mode": "sequential",
          "description": "执行器实现功能"
        },
        {
          "stage": "validation",
          "agents": ["validator"],
          "mode": "sequential",
          "description": "验证器检查质量"
        },
        {
          "stage": "documentation",
          "agents": ["documentor"],
          "mode": "parallel",
          "description": "文档化完成的工作"
        }
      ]
    },
    {
      "name": "bug_fixing",
      "description": "快速的 bug 修复工作流",
      "steps": [
        {
          "stage": "analysis",
          "agents": ["explorer"],
          "mode": "sequential",
          "description": "定位 bug 位置"
        },
        {
          "stage": "planning",
          "agents": ["planner"],
          "mode": "sequential",
          "description": "制定修复方案"
        },
        {
          "stage": "fix",
          "agents": ["executor"],
          "mode": "sequential",
          "description": "实施修复"
        },
        {
          "stage": "verification",
          "agents": ["validator"],
          "mode": "sequential",
          "description": "验证修复"
        }
      ]
    },
    {
      "name": "refactoring",
      "description": "代码重构工作流",
      "steps": [
        {
          "stage": "analysis",
          "agents": ["explorer", "planner"],
          "mode": "parallel",
          "description": "分析现有代码和设计重构方案"
        },
        {
          "stage": "implementation",
          "agents": ["executor"],
          "mode": "sequential",
          "description": "执行重构"
        },
        {
          "stage": "validation",
          "agents": ["validator"],
          "mode": "sequential",
          "description": "验证重构结果"
        }
      ]
    }
  ],
  "communication_protocol": {
    "request_format": {
      "task_id": "string - 唯一任务标识",
      "agent_id": "string - 目标 Agent ID",
      "action": "string - 要执行的操作",
      "input": "object - 输入数据",
      "context": "object - 上下文信息",
      "dependencies": "string[] - 依赖的任务ID",
      "priority": "enum - 优先级: critical, high, medium, low",
      "timeout_ms": "number - 超时时间"
    },
    "response_format": {
      "task_id": "string - 任务 ID",
      "agent_id": "string - 执行的 Agent ID",
      "status": "enum - success, failed, timeout, cancelled",
      "result": "object - 执行结果",
      "metadata": {
        "execution_time_ms": "number",
        "timestamp": "ISO8601 datetime",
        "error": "string or null"
      }
    }
  },
  "state_management": {
    "shared_state": {
      "project_context": "共享的项目上下文信息",
      "completed_tasks": "已完成的任务列表",
      "cached_data": "缓存的分析结果",
      "error_log": "错误日志"
    },
    "agent_local_state": {
      "description": "每个 Agent 可以维护自己的本地状态",
      "example": "Explorer 维护的文件索引"
    }
  },
  "error_handling": {
    "retry_strategy": "exponential_backoff",
    "max_retries": 3,
    "fallback_behavior": "use_cached_result_or_fail",
    "timeout_handling": "cancel_and_reassign"
  }
}
