# Model configuration (global, no business account credentials)
OPENAI_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
OPENAI_API_KEY="your-openai-api-key-here"
MIDSCENE_USE_DOUBAO_VISION=1

MIDSCENE_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MIDSCENE_MODEL_API_KEY=your-midscene-api-key-here
MIDSCENE_MODEL_NAME=your-inference-endpoint-id
MIDSCENE_MODEL_FAMILY=doubao-vision

# Business configuration
DB_PATH=./data/aiflomo.db
# Generate with: node -e "const c=require('crypto');console.log(c.randomBytes(32).toString('hex'))"
SESSION_SECRET=your-32-byte-random-hex-secret-here
CORS_ORIGIN=http://localhost:8082
EXPO_PUBLIC_API_URL=http://localhost:3000/api
