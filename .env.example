# 模型配置（全局，不含业务账号密码）
OPENAI_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
OPENAI_API_KEY="your-api-key-here"

MIDSCENE_USE_DOUBAO_VISION=1
MIDSCENE_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MIDSCENE_MODEL_API_KEY=your-api-key-here
MIDSCENE_MODEL_NAME=ep-20251106190045-6wpnr
MIDSCENE_MODEL_FAMILY=doubao-vision

# 后端服务配置
PORT=3000
NODE_ENV=development

# Session 密钥（生产环境请使用 32+ 字符随机字符串）
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-session-secret-min-32-chars

# 数据库路径（默认为 apps/server/data/aiflomo.db）
# DB_PATH=/absolute/path/to/aiflomo.db

# CORS 白名单（逗号分隔，生产环境必须配置真实域名）
# 开发环境已自动允许 localhost:8081 / 8082 / 5173，无需填写
# 示例（生产）：CORS_ALLOWED_ORIGINS=https://aiflomo.example.com
CORS_ALLOWED_ORIGINS=
